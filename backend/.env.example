#  App 
ENV=development
ALLOWED_ORIGINS=["*"]

#  Redis 
REDIS_URL=redis://localhost:6379/0

#  PostgreSQL 
DATABASE_URL=postgresql+asyncpg://kisan:kisan@localhost:5432/kisanmitra

#  Vertex AI 
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
LLM_MODEL=gemini-2.5-flash
LLM_PROVIDER=gemini
GEMINI_API_KEY=YOUR-GEMINI_API_KEY

#  Agmarknet
AGMARKNET_API_KEY=your-data-gov-in-api-key

#  Timeouts 
TIMEOUT_OPEN_METEO=3.0
TIMEOUT_AGMARKNET=5.0
TIMEOUT_VERTEX_AI=8.0

#  STT 
STT_CONFIDENCE_THRESHOLD=0.65

#  Cache TTLs (seconds) 
CACHE_TTL_WEATHER=10800
CACHE_TTL_MARKET=3600
CACHE_TTL_STALE_WEATHER=86400
CACHE_TTL_STALE_MARKET=21600
